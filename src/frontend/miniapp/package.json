{
  "name": "@tidewise/miniapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:h5": "WATCHPACK_POLLING=true taro build --type h5 --watch",
    "dev:weapp": "WATCHPACK_POLLING=true taro build --type weapp --watch",
    "dev:tt": "taro build --type tt --watch",
    "build:h5": "taro build --type h5 --no-check",
    "build:weapp": "taro build --type weapp --no-check",
    "build:tt": "taro build --type tt --no-check",
    "verify:weapp-output": "node scripts/verify-weapp-output.mjs",
    "preview:weapp": "npm run build:weapp && npm run verify:weapp-output",
    "test": "vitest run src config",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@tarojs/components": "^4.0.0",
    "@tarojs/helper": "^4.0.0",
    "@tarojs/plugin-framework-react": "^4.0.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-tt": "^4.0.0",
    "@tarojs/plugin-platform-weapp": "^4.0.0",
    "@tarojs/react": "^4.0.0",
    "@tarojs/router": "4.2.0",
    "@tarojs/runtime": "^4.0.0",
    "@tarojs/shared": "^4.0.0",
    "@tarojs/taro": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
    "@tarojs/cli": "^4.0.0",
    "@tarojs/webpack5-runner": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "babel-preset-taro": "^4.0.0",
    "eslint": "^8.57.1",
    "eslint-config-taro": "^4.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
