{
  "name": "tidewise-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "src/frontend/miniapp",
    "src/frontend/admin"
  ],
  "scripts": {
    "dev:h5": "npm --workspace @tidewise/miniapp run dev:h5",
    "dev:weapp": "npm --workspace @tidewise/miniapp run dev:weapp",
    "dev:tt": "npm --workspace @tidewise/miniapp run dev:tt",
    "dev:admin": "npm --workspace @tidewise/admin run dev",
    "build:h5": "npm --workspace @tidewise/miniapp run build:h5",
    "build:weapp": "npm --workspace @tidewise/miniapp run build:weapp",
    "preview:weapp": "npm --workspace @tidewise/miniapp run preview:weapp",
    "build:tt": "npm --workspace @tidewise/miniapp run build:tt",
    "build:admin": "npm --workspace @tidewise/admin run build",
    "test": "npm run test:miniapp && npm run test:admin",
    "test:miniapp": "npm --workspace @tidewise/miniapp test",
    "test:admin": "npm --workspace @tidewise/admin test",
    "typecheck": "npm run typecheck:miniapp && npm run typecheck:admin",
    "typecheck:miniapp": "npm --workspace @tidewise/miniapp run typecheck",
    "typecheck:admin": "npm --workspace @tidewise/admin run typecheck",
    "lint": "npm --workspace @tidewise/miniapp run lint",
    "backend:dev": "npm run backend:dev:miniapp",
    "backend:dev:data": "cd src/backend && go run ./services/data/cmd",
    "backend:dev:miniapp": "cd src/backend && go run ./services/miniapp/cmd",
    "backend:dev:admin": "cd src/backend && go run ./services/adminportal/cmd",
    "backend:test": "cd src/backend && go test ./...",
    "backend:fmt": "cd src/backend && gofmt -w .",
    "backend:vet": "cd src/backend && go vet ./...",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
